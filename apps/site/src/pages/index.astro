---
const title = "Layered Graphics";
const description = "A headless, open-source graphics engine for applications, scripts, browsers, and agents.";
const base = `${import.meta.env.BASE_URL}/`.replace(/\/{2,}$/, "/");
const socialImage = new URL(`${base}showcase.png`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0e14" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a class="brand" href={base}>Layered Graphics</a>
      <nav aria-label="Primary">
        <a href={`${base}docs/`}>Docs</a>
        <a href={`${base}playground/`}>Browser proof</a>
        <a href="https://github.com/iamkaf/layeredgraphics">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <p class="meta">MIT · EXPERIMENTAL ALPHA · HEADLESS</p>
        <h1>Graphics authoring<br />without the editor.</h1>
        <p class="lede">A FOSS engine for portable layered documents, command-based editing, authoritative exports, and fast browser previews. Build your own interface—or use no interface at all.</p>
        <p class="links"><a href="https://github.com/iamkaf/layeredgraphics">Source ↗</a><a href={`${base}docs/`}>Documentation →</a></p>
      </section>

      <figure>
        <img src={`${base}showcase.png`} width="1440" height="960" alt="Editable Layered Graphics composition showing a stack of visual layers and the words A canvas for code" />
        <figcaption><span>Built and rendered by Layered Graphics.</span><span><a href={`${base}showcase.kgfx`}>Editable .kgfx ↓</a> · <a href="https://github.com/iamkaf/layeredgraphics/tree/main/examples/showcase">Source ↗</a></span></figcaption>
      </figure>

      <section class="summary">
        <div>
          <h2>Available now</h2>
          <ul><li>Versioned `.kgfx` documents and assets</li><li>Atomic commands, history, diffs, and inspection</li><li>Image, fill, bitmap-text, and group layers</li><li>PNG, JPEG, and WebP export</li><li>Rust, CLI, browser WASM, and native Node</li><li>Retained worker previews with WebGPU/Canvas2D</li></ul>
        </div>
        <div>
          <h2>Not implemented</h2>
          <ul class="muted"><li>Masks and clipping chains</li><li>Vector shapes and gradients</li><li>Painting and selections</li><li>Adjustments and filters</li><li>Styled editor components</li></ul>
        </div>
      </section>

      <section class="architecture">
        <div><span>APP · AGENT · CLI · SDK</span><i>↓ operations</i><strong>CANONICAL RUST DOCUMENT</strong><i>↓</i><span>.KGFX · IMAGE EXPORT · BROWSER PREVIEW</span></div>
        <pre><code>git clone https://github.com/iamkaf/layeredgraphics.git
cd layeredgraphics
corepack enable && pnpm install
./examples/showcase/build.sh
pnpm test</code></pre>
      </section>
    </main>

    <footer><span>Layered Graphics is MIT licensed.</span><span><a href="https://github.com/iamkaf/layeredgraphics/blob/main/CONTRIBUTING.md">Contributing</a> · <a href={`${base}docs/project/roadmap/`}>Roadmap</a> · <a href="https://github.com/iamkaf/layeredgraphics">GitHub</a></span></footer>
  </body>
</html>

<style>
  :global(*){box-sizing:border-box}:global(html){background:#0b0e14;color:#f2f4f8;font-family:Inter,ui-sans-serif,system-ui,sans-serif}:global(body){margin:0}:global(a){color:inherit}header,main,footer{width:min(1120px,calc(100% - 3rem));margin-inline:auto}header{height:72px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #29303d}.brand{font-weight:800;text-decoration:none;letter-spacing:-.025em}nav{display:flex;gap:1.5rem}nav a,.links a,footer a{color:#aeb7c5;font-size:.84rem;text-decoration:none}nav a:hover,.links a:hover,footer a:hover,figcaption a:hover{color:#58e6cd}.hero{padding:8rem 0 5rem;max-width:940px}.meta{color:#58e6cd;font:700 .68rem ui-monospace,monospace;letter-spacing:.12em}.hero h1{font-size:clamp(4rem,9vw,7.8rem);line-height:.92;letter-spacing:-.065em;margin:1.6rem 0 2rem}.lede{max-width:740px;color:#aeb7c5;font-size:1.2rem;line-height:1.7}.links{display:flex;gap:1.5rem;margin-top:2rem}.links a{text-decoration:underline;text-underline-offset:.25rem}figure{margin:0;border:1px solid #303846;background:#080a0f}figure img{display:block;width:100%;height:auto}figcaption{display:flex;justify-content:space-between;gap:1rem;padding:.8rem 1rem;color:#788394;font:.68rem ui-monospace,monospace}.summary{display:grid;grid-template-columns:1fr 1fr;gap:5rem;padding:6rem 0;border-bottom:1px solid #29303d}.summary h2{font-size:1rem;margin:0 0 1.5rem}.summary ul{list-style:none;padding:0;margin:0}.summary li{padding:.65rem 0;border-top:1px solid #242b36;color:#c7ced8;font-size:.86rem}.summary li:before{content:"+";color:#58e6cd;margin-right:.75rem}.summary .muted li{color:#7f8998}.summary .muted li:before{content:"–";color:#ff8375}.architecture{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;padding:6rem 0}.architecture>div{display:grid;gap:.9rem;text-align:center;font:700 .68rem ui-monospace,monospace}.architecture strong{padding:1.2rem;border:1px solid #7c65e8;color:#cfc6ff}.architecture i{color:#667284;font-style:normal}.architecture pre{margin:0;padding:1.4rem;overflow:auto;border:1px solid #303846;background:#07090d;color:#cfd5df;font:.72rem/1.8 ui-monospace,monospace}footer{display:flex;justify-content:space-between;gap:1rem;padding:2rem 0;border-top:1px solid #29303d;color:#748091;font-size:.72rem}
  @media(max-width:700px){header,main,footer{width:min(100% - 1.5rem,1120px)}header nav a:not(:last-child){display:none}.hero{padding:5rem 0 3rem}.hero h1{font-size:3.15rem}.lede{font-size:1rem}.links{flex-wrap:wrap}figcaption{display:grid}.summary,.architecture{grid-template-columns:1fr;gap:3rem;padding:4rem 0}footer{flex-direction:column}}
</style>
