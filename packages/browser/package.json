{
  "name": "@layered-graphics/browser",
  "version": "0.1.0-alpha.1",
  "description": "Worker-owned retained browser previews for Layered Graphics.",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/iamkaf/layeredgraphics.git", "directory": "packages/browser" },
  "homepage": "https://iamkaf.github.io/layeredgraphics/",
  "keywords": ["graphics", "webgpu", "worker", "wasm", "canvas"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./worker": { "types": "./dist/worker.d.ts", "import": "./dist/worker.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@layered-graphics/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "7.0.2"
  }
}
