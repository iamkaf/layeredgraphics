{
  "name": "layered-graphics-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r build",
    "check": "cargo check --workspace && pnpm -r check",
    "test": "cargo test --workspace && pnpm -r test",
    "site:dev": "pnpm --filter @layered-graphics/site dev",
    "site:build": "pnpm --filter @layered-graphics/site build"
  }
}
